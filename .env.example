# LumeOS Environment Variables
# Copy to .env.local and fill in values

# Supabase (Local Development)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Control Plane Ports (Threadripper)
SAT_CHECK_PORT=9001
SCHEDULER_PORT=9002
ORCHESTRATOR_API_PORT=9000

# Domain API Ports (local dev)
NUTRITION_API_PORT=4200
TRAINING_API_PORT=4201
RECOVERY_API_PORT=4202
COACH_API_PORT=4203
MEDICAL_API_PORT=4204

# DGX Spark Endpoints (all on port 8001)
SPARK_A_ENDPOINT=http://192.168.0.128:8001
SPARK_B_ENDPOINT=http://192.168.0.188:8001

# Execution Token (Ed25519)
# Generate with: node -e "import('@lumeos/execution-token').then(m => m.generateKeyPair().then(console.log))"
ED25519_PRIVATE_KEY=your-base64-private-key
ED25519_PUBLIC_KEY=your-base64-public-key

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Claude Code (Brain Layer)
ANTHROPIC_API_KEY=your-anthropic-key
