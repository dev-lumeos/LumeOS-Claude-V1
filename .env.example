# LumeOS Environment Variables
# Copy to .env.local and fill in values

# Supabase (Local Development)
SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Control Plane Ports (Threadripper)
WO_CLASSIFIER_PORT=9000
SAT_CHECK_PORT=9001
SCHEDULER_PORT=9002
GOVERNANCE_COMPILER_PORT=9003
ORCHESTRATOR_API_PORT=9000

# Control Plane URLs (used by clients/tests)
WO_CLASSIFIER_URL=http://localhost:9000
SAT_CHECK_URL=http://localhost:9001
SCHEDULER_URL=http://localhost:9002
GOVERNANCE_COMPILER_URL=http://localhost:9003

# Domain API Ports (local dev)
NUTRITION_API_PORT=4200
TRAINING_API_PORT=4201
RECOVERY_API_PORT=4202
COACH_API_PORT=4203
MEDICAL_API_PORT=4204

# DGX Spark Endpoints (all on port 8001)
SPARK_A_ENDPOINT=http://192.168.0.128:8001
NEMOTRON_ENDPOINT=http://192.168.0.128:8002
SPARK_B_ENDPOINT=http://192.168.0.188:8001
SPARK_A_MODEL=qwen3.6-35b
SPARK_B_MODEL=qwen3-coder-30b

# Execution Token (Ed25519) — generate fresh with:
#   npx tsx tools/scripts/generate-ed25519-keys.ts >> .env
ED25519_PRIVATE_KEY=your-base64-private-key
ED25519_PUBLIC_KEY=your-base64-public-key

# Workspace root (absolute path) — picked up by services + test scripts
WORKSPACE_ROOT=/path/to/LumeOS-Claude-V1

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Claude Code (Brain Layer)
ANTHROPIC_API_KEY=your-anthropic-key

# Paperclip (Agent Orchestration)
PAPERCLIP_BASE_URL=http://localhost:3100
PAPERCLIP_API_KEY=pcp_board_your-api-key-here

# LightRAG (Knowledge Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# lean-ctx (Token Compression)
LEAN_CTX_PROJECT=lumeos
