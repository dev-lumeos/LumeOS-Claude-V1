# LumeOS Environment Variables
# Copy to .env.local and fill in values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API Ports (local dev)
ORCHESTRATOR_API_PORT=9000
NUTRITION_API_PORT=4200
TRAINING_API_PORT=4201
RECOVERY_API_PORT=4202
COACH_API_PORT=4203
MEDICAL_API_PORT=4204

# DGX Spark Endpoints
SPARK_A_ENDPOINT=http://spark-a:8001
SPARK_B_ENDPOINT=http://spark-b:8002
SPARK_A_REVIEW_ENDPOINT=http://spark-a:8011
SPARK_B_REVIEW_ENDPOINT=http://spark-b:8013

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Claude Code (Brain Layer)
ANTHROPIC_API_KEY=your-anthropic-key
