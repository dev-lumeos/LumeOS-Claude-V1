{
  "profile_version": 1,
  "project_id": "beauty-club",
  "display_name": "Beauty Club",
  "profile_kind": "example",
  "active": false,
  "repo_root": "<ABSOLUTE_REPO_PATH>",
  "governance_root": "system",
  "specs_root": "docs/specs",
  "workorders_root": "system/workorders",
  "reports_root": "system/reports",
  "memory_root": "system/memory",
  "learning_root": "docs/project/governance-learning",
  "runtime_state_root": "system/state",
  "approval_root": "system/approval",
  "raw_data_paths": [],
  "ignored_local_paths": [
    "system/reports/codex-worker/"
  ],
  "product_gate": {
    "status": "closed",
    "reason": "Product work remains blocked until Tom opens the Beauty Club project gate.",
    "conditional_planning_allowed": false
  },
  "forbidden_paths": [
    ".env",
    ".env.*",
    "system/state/runtime_state.json",
    "system/state/*.lock",
    "system/approval/queue.json"
  ],
  "forbidden_commands": [
    "supabase db reset",
    "supabase db push",
    "supabase db push --linked",
    "supabase migration up",
    "migration execution"
  ],
  "required_checkers": [
    "governance-invariant-check",
    "agent-contract-check",
    "model-runtime-check",
    "governance-learning-check"
  ],
  "default_operator_batch": "",
  "default_governance_batch": "",
  "default_branch_prefix": "goal/",
  "source_chain_policy": {
    "module_index_required": true,
    "nutrition_priority_required": false,
    "raw_sources_require_explicit_allow": true
  },
  "allowed_domain_paths": [
    "docs/specs/BeautyClub/",
    "docs/project/",
    "system/workorders/beauty-club/"
  ],
  "runtime_policy": {
    "require_live_hardware": false
  },
  "docs_entrypoints": [
    "docs/specs/BeautyClub/INDEX.md"
  ],
  "ui_settings": {
    "selectable": false,
    "notice": "Example only. Do not activate without Tom's real repo path and policy."
  },
  "promotion_policy": {
    "require_clean_worktree": true,
    "block_runtime_artifacts": true,
    "block_raw_local_data": true,
    "require_typecheck": true
  },
  "codex_worker_policy": {
    "enabled": false,
    "allowed_agents": [
      "senior-coding-agent"
    ],
    "require_explicit_workorder_flag": true,
    "default_timeout_ms": 120000
  }
}
