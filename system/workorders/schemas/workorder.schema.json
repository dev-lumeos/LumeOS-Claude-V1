{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "lumeos/workorder",
  "title": "LUMEOS Workorder",
  "type": "object",
  "required": ["workorder_id", "agent_id", "task", "scope_files", "acceptance_criteria", "negative_constraints"],
  "properties": {
    "workorder_id":         { "type": "string", "pattern": "^WO-[a-z]+-[0-9]+$" },
    "run_id":               { "type": "string", "pattern": "^RUN-[0-9]{8}-[0-9]+$" },
    "agent_id":             { "type": "string" },
    "task":                 { "type": "string", "minLength": 10 },
    "scope_files":          { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "context_files":        { "type": "array", "items": { "type": "string" }, "default": [] },
    "acceptance_files":     { "type": "array", "items": { "type": "string" }, "default": [] },
    "acceptance_criteria":  { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "negative_constraints": { "type": "array", "items": { "type": "string" }, "minItems": 4 },
    "required_skills":      { "type": "array", "items": { "type": "string" }, "default": [] },
    "optional_skills":      { "type": "array", "items": { "type": "string" }, "default": [] },
    "blocked_by":           { "type": "array", "items": { "type": "string" }, "default": [] },
    "phase":                { "type": "integer", "enum": [1, 2, 3] },
    "requires_approval":    { "type": "boolean", "default": false },
    "correlation_id":       { "type": "string" },
    "priority":             { "type": "string", "enum": ["low", "normal", "high", "critical"], "default": "normal" },
    "quality_critical":     { "type": "boolean", "default": false },
    "risk_category": {
      "type": "string",
      "enum": [
        "standard", "docs", "i18n", "test",
        "db-migration", "security", "auth", "rls",
        "medical", "payments", "shared-core", "architecture", "release"
      ],
      "default": "standard",
      "description": "Explizite Risk-Kategorie. Hat Vorrang vor automatischer Inferenz aus dem Task-Text. Bestimmt Spark-D-Pflicht, Auto-Retry-Erlaubnis und Human-Approval-Anforderung."
    },
    "files_blocked": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Pfade die der Worker explizit NICHT berühren darf. Wird von authorize-tool-call.ts gegen jeden Write-Versuch geprüft (A.2)."
    },
    "validation_commands": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["pnpm tsc --noEmit"],
      "description": "Commands die nach Execution laufen müssen. Standard: tsc check. Kann erweitert werden z.B. um pnpm test."
    },
    "rollback_hint": {
      "type": "string",
      "description": "Rollback-Hinweis oder -Befehl. Optional, empfohlen bei risk_category=db-migration."
    }
  },
  "if": {
    "properties": { "risk_category": { "const": "db-migration" } },
    "required": ["risk_category"]
  },
  "then": {
    "required": ["rollback_hint"],
    "properties": {
      "rollback_hint": { "type": "string", "minLength": 5 }
    }
  }
}
