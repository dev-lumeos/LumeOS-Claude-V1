{
  "dashboard": {
    "uid": "lumeos-hardware",
    "title": "LumeOS — Hardware & vLLM",
    "tags": ["lumeos", "hardware", "prometheus", "vllm"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 0,
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Threadripper — CPU %",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent", "min": 0, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]},
            "noValue": "exporter not installed"
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "100 - (avg(rate(windows_cpu_time_total{mode=\"idle\",job=\"threadripper-windows\"}[2m])) * 100)"
        }]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Threadripper — RAM Used",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "decgbytes", "decimals": 1,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 64 },
              { "color": "red", "value": 96 }
            ]},
            "noValue": "exporter not installed"
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "(windows_memory_physical_total_bytes{job=\"threadripper-windows\"} - windows_memory_physical_free_bytes{job=\"threadripper-windows\"}) / 1024 / 1024 / 1024"
        }]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "RTX 5090 — Temp",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "celsius", "min": 20, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 82 },
              { "color": "red", "value": 90 }
            ]},
            "noValue": "exporter not installed"
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "nvidia_smi_temperature_gpu{job=\"threadripper-windows\"}"
        }]
      },
      {
        "id": 4,
        "type": "stat",
        "title": "RTX 5090 — GPU Util",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent", "min": 0, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 92 }
            ]},
            "noValue": "exporter not installed"
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "nvidia_smi_utilization_gpu{job=\"threadripper-windows\"}"
        }]
      },

      {
        "id": 5,
        "type": "stat",
        "title": "Spark A — GPU Temp",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "celsius", "min": 20, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 82 },
              { "color": "red", "value": 90 }
            ]},
            "noValue": "DCGM exporter not installed"
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "DCGM_FI_DEV_GPU_TEMP{host=\"spark-a\"}"
        }]
      },
      {
        "id": 6,
        "type": "stat",
        "title": "Spark A — Requests Running",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 6, "y": 4, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]}
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "vllm:num_requests_running{host=\"spark-a\"}"
        }]
      },
      {
        "id": 7,
        "type": "stat",
        "title": "Spark A — Tokens/s",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short", "decimals": 1,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "blue", "value": null }
            ]}
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "rate(vllm:generation_tokens_total{host=\"spark-a\"}[1m])"
        }]
      },
      {
        "id": 8,
        "type": "stat",
        "title": "Spark A — KV Cache %",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 18, "y": 4, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent", "min": 0, "max": 100, "decimals": 1,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]}
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "vllm:kv_cache_usage_perc{host=\"spark-a\"} * 100"
        }]
      },

      {
        "id": 9,
        "type": "stat",
        "title": "Spark B — GPU Temp",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "celsius", "min": 20, "max": 100,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 82 },
              { "color": "red", "value": 90 }
            ]},
            "noValue": "DCGM exporter not installed"
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "DCGM_FI_DEV_GPU_TEMP{host=\"spark-b\"}"
        }]
      },
      {
        "id": 10,
        "type": "stat",
        "title": "Spark B — Requests Running",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]}
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "vllm:num_requests_running{host=\"spark-b\"}"
        }]
      },
      {
        "id": 11,
        "type": "stat",
        "title": "Spark B — Tokens/s",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short", "decimals": 1,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "blue", "value": null }
            ]}
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "rate(vllm:generation_tokens_total{host=\"spark-b\"}[1m])"
        }]
      },
      {
        "id": 12,
        "type": "stat",
        "title": "Spark B — KV Cache %",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "textMode": "auto", "colorMode": "value", "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent", "min": 0, "max": 100, "decimals": 1,
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]}
          }
        },
        "targets": [{
          "refId": "A", "instant": true,
          "expr": "vllm:kv_cache_usage_perc{host=\"spark-b\"} * 100"
        }]
      },

      {
        "id": 13,
        "type": "timeseries",
        "title": "Generation Tokens/s — Spark A vs Spark B",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
        "options": {
          "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] },
          "tooltip": { "mode": "multi" }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
          }
        },
        "targets": [
          {
            "refId": "A",
            "expr": "rate(vllm:generation_tokens_total{host=\"spark-a\"}[1m])",
            "legendFormat": "Spark A — generation"
          },
          {
            "refId": "B",
            "expr": "rate(vllm:generation_tokens_total{host=\"spark-b\"}[1m])",
            "legendFormat": "Spark B — generation"
          },
          {
            "refId": "C",
            "expr": "rate(vllm:prompt_tokens_total{host=\"spark-a\"}[1m])",
            "legendFormat": "Spark A — prompt"
          },
          {
            "refId": "D",
            "expr": "rate(vllm:prompt_tokens_total{host=\"spark-b\"}[1m])",
            "legendFormat": "Spark B — prompt"
          }
        ]
      },
      {
        "id": 14,
        "type": "timeseries",
        "title": "Time to First Token (p50 / p95)",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
        "options": {
          "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] },
          "tooltip": { "mode": "multi" }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s", "decimals": 3,
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
          }
        },
        "targets": [
          {
            "refId": "A",
            "expr": "histogram_quantile(0.5, sum by (le, host) (rate(vllm:time_to_first_token_seconds_bucket[5m])))",
            "legendFormat": "{{host}} p50"
          },
          {
            "refId": "B",
            "expr": "histogram_quantile(0.95, sum by (le, host) (rate(vllm:time_to_first_token_seconds_bucket[5m])))",
            "legendFormat": "{{host}} p95"
          }
        ]
      },

      {
        "id": 15,
        "type": "timeseries",
        "title": "Requests Running & Waiting",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 0, "y": 20, "w": 12, "h": 7 },
        "options": {
          "legend": { "displayMode": "table", "placement": "bottom" },
          "tooltip": { "mode": "multi" }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 }
          }
        },
        "targets": [
          { "refId": "A", "expr": "vllm:num_requests_running{host=\"spark-a\"}", "legendFormat": "Spark A — running" },
          { "refId": "B", "expr": "vllm:num_requests_waiting{host=\"spark-a\"}", "legendFormat": "Spark A — waiting" },
          { "refId": "C", "expr": "vllm:num_requests_running{host=\"spark-b\"}", "legendFormat": "Spark B — running" },
          { "refId": "D", "expr": "vllm:num_requests_waiting{host=\"spark-b\"}", "legendFormat": "Spark B — waiting" }
        ]
      },
      {
        "id": 16,
        "type": "timeseries",
        "title": "Request Success Rate (req/s)",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 12, "y": 20, "w": 12, "h": 7 },
        "options": {
          "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] },
          "tooltip": { "mode": "multi" }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "reqps", "decimals": 3,
            "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }
          }
        },
        "targets": [
          { "refId": "A", "expr": "rate(vllm:request_success_total{host=\"spark-a\"}[1m])", "legendFormat": "Spark A" },
          { "refId": "B", "expr": "rate(vllm:request_success_total{host=\"spark-b\"}[1m])", "legendFormat": "Spark B" }
        ]
      },

      {
        "id": 17,
        "type": "table",
        "title": "Prometheus Scrape Target Health",
        "datasource": { "type": "prometheus", "uid": "bfk0um9jbfi0wd" },
        "gridPos": { "x": 0, "y": 27, "w": 24, "h": 6 },
        "options": { "showHeader": true, "cellHeight": "sm" },
        "fieldConfig": {
          "defaults": {
            "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Value" },
              "properties": [
                { "id": "displayName", "value": "up" },
                { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
                {
                  "id": "mappings",
                  "value": [
                    { "type": "value", "options": { "1": { "color": "green", "text": "UP",   "index": 0 } } },
                    { "type": "value", "options": { "0": { "color": "red",   "text": "DOWN", "index": 1 } } }
                  ]
                }
              ]
            }
          ]
        },
        "targets": [{
          "refId": "A", "instant": true, "format": "table",
          "expr": "up"
        }],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": { "Time": true, "__name__": true },
              "indexByName": { "job": 0, "host": 1, "instance": 2, "Value": 3 }
            }
          }
        ]
      }
    ]
  },
  "overwrite": true,
  "message": "Initial import — hardware & vLLM monitoring"
}
