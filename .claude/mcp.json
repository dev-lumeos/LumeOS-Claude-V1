{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from", "git+https://github.com/oraios/serena",
        "serena", "start-mcp-server",
        "--context", "ide-assistant",
        "--project", "${workspaceFolder}"
      ]
    },
    "claude-mem": {
      "command": "npx",
      "args": ["claude-mem", "mcp"],
      "env": {
        "CMEM_PROJECT": "lumeos-claude-v1"
      }
    }
  }
}
