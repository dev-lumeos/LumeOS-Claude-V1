{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "serena": {
      "command": "uvx",
      "args": ["--from", "serena", "serena-mcp-server"],
      "env": {
        "PROJECT_ROOT": "${workspaceFolder}"
      }
    },
    "claude-mem": {
      "command": "npx",
      "args": ["claude-mem", "mcp"],
      "env": {
        "CMEM_PROJECT": "lumeos-claude-v1"
      }
    }
  }
}
